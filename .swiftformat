# swiftformat 설정 — .swiftlint.yml 과 정렬 (포매터 간 핑퐁 churn 방지)
# 핵심: trailingCommas — swiftformat 기본은 멀티라인 컬렉션에 trailing comma 를 추가하지만
# SwiftLint 기본 룰(trailing_comma)은 이를 위반으로 잡는다 → inline 으로 정렬.
--commas inline

# .swiftlint.yml 과 동일 기준
--indent 4
--maxwidth 120
--swiftversion 5.0   # pbxproj SWIFT_VERSION (미지정 시 일부 룰 비활성 경고)

# 검사 제외 (swift-quality 훅은 파일 단위 실행이지만, 수동 전체 실행 대비)
--exclude DerivedData,build,.build,woni_app.xcodeproj
